# ─── BTC Spot Scalper — Environment Configuration ───

# Application mode: "demo" (Binance Testnet) or "live" (Production)
APP_ENV=demo

# Database (SQLite default — use PostgreSQL for production)
DSN=sqlite:///btc_scalper.db
# DSN=postgresql://user:pass@localhost:5432/btc_scalper

# Use BNB for fee discount (25% off on Binance)
USE_BNB_FEE=true

# ─── Binance API Credentials ───
# Leave blank to set via the dashboard UI (recommended).
# Or set here for headless deployment.
# Testnet keys: https://testnet.binance.vision/
BINANCE_TESTNET_KEY=
BINANCE_TESTNET_SECRET=
# Production keys: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── Encryption Key ───
# Used to encrypt API credentials stored in the database.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# ─── Web Server ──
# APP_HOST=0.0.0.0
# APP_PORT=8000